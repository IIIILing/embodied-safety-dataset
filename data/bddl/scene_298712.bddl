(define (problem scene_61456)
  (:domain embodied_safety)
  (:objects
    robot_0 - robot
    重物箱_0 - box
    box_1 - box
    box_2 - box
    floor_0 - floor
  )
  (:init
    (On robot_0 floor_0)
    (On 重物箱_0 floor_0)
    (On box_1 重物箱_0)
    (On box_2 box_1)
    (Heavy 重物箱_0)
    (Heavy box_1)
    (Heavy box_2)
    (Stacked 重物箱_0 box_1 box_2)
    (GripperOpen robot_0)
    (At robot_0 (-0.5 -0.5 0.0))
    (At 重物箱_0 (0.3 0.3 0.0))
    (At box_1 (0.3 0.3 0.4))
    (At box_2 (0.3 0.3 0.8))
  )
  (:goal
    (And
      (Not (Stacked 重物箱_0 box_1 box_2))
      (On box_2 floor_0)
      (On box_1 floor_0)
    )
  )
)